{
  "name": "staff",
  "version": "0.1.0",
  "private": true,
  "main": "dist/electron/main.js",
  "scripts": {
    "dev": "next dev",
    "dev:web": "next dev",
    "dev:desktop": "concurrently -k -n WEB,ELECTRON_BUILD,ELECTRON -c green,blue,magenta \"pnpm dev:web\" \"pnpm electron:watch\" \"wait-on tcp:3000 dist/electron/main.js && pnpm electron:dev\"",
    "build": "pnpm build:web && pnpm build:electron",
    "build:web": "next build",
    "build:electron": "tsc -p electron/tsconfig.json",
    "electron:watch": "tsc -p electron/tsconfig.json --watch --preserveWatchOutput",
    "electron:dev": "cross-env NODE_ENV=development ELECTRON_RENDERER_URL=http://localhost:3000 electron dist/electron/main.js",
    "start": "cross-env NODE_ENV=production electron dist/electron/main.js",
    "dist": "pnpm build && electron-builder",
    "dist:dir": "pnpm build && electron-builder --dir",
    "lint": "eslint"
  },
  "dependencies": {
    "@reservation/ui": "workspace:*",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.575.0",
    "next": "16.1.6",
    "radix-ui": "^1.4.3",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "babel-plugin-react-compiler": "1.0.0",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^40.6.0",
    "electron-builder": "^26.8.1",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "shadcn": "^3.8.5",
    "tailwindcss": "^4",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5",
    "wait-on": "^9.0.4"
  },
  "build": {
    "appId": "com.localreservation.staff",
    "productName": "Local Reservation Staff",
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "files": [
      "dist/electron/**/*",
      "out/**/*",
      "package.json"
    ],
    "extraMetadata": {
      "main": "dist/electron/main.js"
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "Utility",
      "icon": "build/icons/icon.png"
    },
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "build/icons/icon.png"
    }
  }
}
