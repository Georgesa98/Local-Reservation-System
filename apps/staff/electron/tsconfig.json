{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "types": ["node", "electron"],
    "skipLibCheck": true,
    "esModuleInterop": true,
    "strict": true,
    "noEmit": false,
    "sourceMap": true,
    "outDir": "../dist/electron"
  },
  "include": ["./**/*"]
}
